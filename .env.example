ENVIRONMENT=local
LOG_LEVEL=INFO
DEBUG=false

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_RAW_EVENTS_TOPIC=ecommerce_events

# Spark
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_TRIGGER_INTERVAL=10 seconds

# Delta Lake
DELTA_LAKE_PATH=/data/lakehouse
DELTA_VACUUM_RETENTION_HOURS=168

# API
API_HOST=0.0.0.0
API_PORT=8000
